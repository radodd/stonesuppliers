# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — Stone Suppliers
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Local Dev ─────────────────────────────────────────────────────────────────
PORT=3030

# ── Supabase ──────────────────────────────────────────────────────────────────
# Anon key (safe for client — subject to Supabase RLS policies)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_API_KEY=your-supabase-anon-key

# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-production-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key

# Sender address — must be a verified domain in your Resend account
RESEND_FROM_EMAIL=Stone Suppliers <noreply@yourdomain.com>

# Recipient address — where quote/contact form submissions are delivered
RESEND_TO_EMAIL=recipient@yourdomain.com

# ── Analytics ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
